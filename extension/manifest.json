{
  "manifest_version": 3,
  "name": "BehaviorSense Analyzer",
  "version": "1.0",
  "description": "Detect phishing, toxicity and stress in online text.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/analyze"
  ],
  "action": {
    "default_popup": "popup.html"
    
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}